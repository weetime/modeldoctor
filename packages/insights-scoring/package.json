{
  "name": "@modeldoctor/insights-scoring",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared scoring pure-functions for Test Insights (web + api)",
  "engines": {
    "node": ">=20.11"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./src/index.ts"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && tsc -p tsconfig.build.cjs.json && node ./scripts/rename-cjs.mjs",
    "dev": "tsc -w -p tsconfig.build.json --preserveWatchOutput",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src",
    "format": "biome format --write src",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@modeldoctor/contracts": "workspace:*",
    "@modeldoctor/tool-adapters": "workspace:*"
  }
}
