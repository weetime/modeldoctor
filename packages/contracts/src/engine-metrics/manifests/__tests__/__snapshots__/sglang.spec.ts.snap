// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`sglang manifest > snapshot of rendered PromQL is stable 1`] = `
[
  {
    "exprs": [
      "sum(sglang:num_running_reqs{model_name="test-model"})",
    ],
    "key": "active_requests",
  },
  {
    "exprs": [
      "histogram_quantile(0.99, sum by (le) (rate(sglang:time_to_first_token_seconds_bucket{model_name="test-model"}[5m]))) * 1000",
    ],
    "key": "ttft_p99",
  },
  {
    "exprs": [
      "sum(rate(sglang:request_success_total{model_name="test-model"}[5m])) / clamp_min(sum(rate(sglang:request_total{model_name="test-model"}[5m])), 1)",
    ],
    "key": "success_rate",
  },
  {
    "exprs": [
      "label_replace(histogram_quantile(0.50, sum by (le) (rate(sglang:e2e_request_latency_seconds_bucket{model_name="test-model"}[1m]))) * 1000, "series", "p50", "", ".*") or label_replace(histogram_quantile(0.95, sum by (le) (rate(sglang:e2e_request_latency_seconds_bucket{model_name="test-model"}[1m]))) * 1000, "series", "p95", "", ".*") or label_replace(histogram_quantile(0.99, sum by (le) (rate(sglang:e2e_request_latency_seconds_bucket{model_name="test-model"}[1m]))) * 1000, "series", "p99", "", ".*")",
    ],
    "key": "e2e_latency",
  },
  {
    "exprs": [
      "sum(sglang:gen_throughput{model_name="test-model"})",
    ],
    "key": "token_throughput_out",
  },
  {
    "exprs": [
      "sum(sglang:num_queue_reqs{model_name="test-model"})",
    ],
    "key": "request_queue_time",
  },
  {
    "exprs": [
      "clamp_max(100 * sglang:token_usage{model_name="test-model"}, 100)",
    ],
    "key": "kv_cache_usage",
  },
  {
    "exprs": [
      "label_replace(sum(sglang:num_running_reqs{model_name="test-model"}), "series", "running", "", ".*") or label_replace(sum(sglang:num_queue_reqs{model_name="test-model"}), "series", "waiting", "", ".*")",
    ],
    "key": "scheduler_state",
  },
  {
    "exprs": [
      "sum by (finished_reason) (rate(sglang:request_success_total{model_name="test-model"}[1m]))",
    ],
    "key": "finish_reason",
  },
]
`;
