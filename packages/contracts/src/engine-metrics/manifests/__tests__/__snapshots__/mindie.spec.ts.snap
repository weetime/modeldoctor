// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`mindie manifest > snapshot is stable 1`] = `
[
  {
    "exprs": [
      "sum(mindie_running_request_count{model_name="test-model"})",
    ],
    "key": "active_requests",
  },
  {
    "exprs": [
      "histogram_quantile(0.99, sum by (le) (rate(mindie_first_token_duration_seconds_bucket{model_name="test-model"}[5m]))) * 1000",
    ],
    "key": "ttft_p99",
  },
  {
    "exprs": [
      "label_replace(histogram_quantile(0.50, sum by (le) (rate(mindie_request_duration_seconds_bucket{model_name="test-model"}[1m]))) * 1000, "series", "p50", "", ".*") or label_replace(histogram_quantile(0.95, sum by (le) (rate(mindie_request_duration_seconds_bucket{model_name="test-model"}[1m]))) * 1000, "series", "p95", "", ".*") or label_replace(histogram_quantile(0.99, sum by (le) (rate(mindie_request_duration_seconds_bucket{model_name="test-model"}[1m]))) * 1000, "series", "p99", "", ".*")",
    ],
    "key": "e2e_latency",
  },
  {
    "exprs": [
      "sum(rate(mindie_generation_tokens_total{model_name="test-model"}[1m]))",
    ],
    "key": "token_throughput_out",
  },
  {
    "exprs": [
      "clamp_max(100, 100 * mindie_kv_cache_usage_ratio{model_name="test-model"})",
    ],
    "key": "kv_cache_usage",
  },
]
`;
