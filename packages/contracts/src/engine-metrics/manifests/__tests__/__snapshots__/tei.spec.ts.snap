// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`tei manifest > snapshot is stable 1`] = `
[
  {
    "exprs": [
      "sum(te_request_count{state="running"})",
    ],
    "key": "active_requests",
  },
  {
    "exprs": [
      "sum(rate(te_request_count{state="success"}[5m])) / clamp_min(sum(rate(te_request_count{state=~"success|failure"}[5m])), 1)",
    ],
    "key": "success_rate",
  },
  {
    "exprs": [
      "histogram_quantile(0.99, sum by (le) (rate(te_request_duration_seconds_bucket[5m]))) * 1000",
    ],
    "key": "request_latency_p99",
  },
  {
    "exprs": [
      "sum(rate(te_tokenize_count[1m]))",
    ],
    "key": "tokenize_rate",
  },
  {
    "exprs": [
      "sum(rate(te_request_count{state="success"}[1m]))",
    ],
    "key": "embedding_rate",
  },
  {
    "exprs": [
      "label_replace(sum(te_queue_size), "series", "queue_size", "", ".*") or label_replace(histogram_quantile(0.99, sum by (le) (rate(te_queue_duration_seconds_bucket[1m]))) * 1000, "series", "queue_p99_ms", "", ".*")",
    ],
    "key": "queue_metrics",
  },
]
`;
