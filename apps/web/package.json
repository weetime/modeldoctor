  "devDependencies": {
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/react": "^18.3",
    "@types/react-dom": "^18.3",
    "@vitejs/plugin-react": "^4",
    "@vitest/ui": "^2.1.9",
    "autoprefixer": "^10",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^24",
    "postcss": "^8",
