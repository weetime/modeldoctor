    "@fontsource-variable/jetbrains-mono": "^5.1.2",
    "@hookform/resolvers": "^3",
    "@modeldoctor/contracts": "workspace:*",
    "@modeldoctor/insights-scoring": "workspace:*",
    "@modeldoctor/tool-adapters": "workspace:*",
    "@radix-ui/react-alert-dialog": "^1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1",
    "@radix-ui/react-dropdown-menu": "^2",
    "@radix-ui/react-label": "^2",
    "@radix-ui/react-popover": "^1",
    "@radix-ui/react-progress": "^1",
    "@radix-ui/react-radio-group": "^1",
    "@radix-ui/react-scroll-area": "^1",
    "@radix-ui/react-select": "^2",
    "@radix-ui/react-separator": "^1",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1",
    "@radix-ui/react-switch": "^1",
    "@radix-ui/react-tabs": "^1",
    "@radix-ui/react-tooltip": "^1",
    "@tanstack/react-query": "^5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2",
    "cmdk": "^1.0.4",
    "date-fns": "^4.1.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "i18next": "^23",
    "idb": "^8.0.3",
    "lucide-react": "^1.14.0",
    "react": "^18.3",
    "react-dom": "^18.3",
    "react-hook-form": "^7",
    "react-hotkeys-hook": "^5.3.2",
    "react-i18next": "^14",
