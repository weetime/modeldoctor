exports[`genChatSnippets > renders curl/python/node with placeholder API key (snapshot) 1`] = `
"curl -X POST http://upstream.test/v1/chat/completions \\
  -H "Authorization: Bearer <YOUR_API_KEY>" \\
  -H "Content-Type: application/json" \\
  -d '{
  "model": "m1",
  "messages": [
    {
      "role": "user",
      "content": "hi"
    }
  ],
  "temperature": 0.5,
  "max_tokens": 100
}'"
`;

exports[`genChatSnippets > renders curl/python/node with placeholder API key (snapshot) 2`] = `
"from openai import OpenAI

client = OpenAI(base_url="http://upstream.test", api_key="<YOUR_API_KEY>")
resp = client.chat.completions.create(
    model="m1",
    messages=[{"role":"user","content":"hi"}],
    temperature=0.5,
    max_tokens=100,
)
print(resp.choices[0].message.content)"
`;

exports[`genChatSnippets > renders curl/python/node with placeholder API key (snapshot) 3`] = `
"import OpenAI from "openai";

const client = new OpenAI({
  baseURL: "http://upstream.test",
  apiKey: "<YOUR_API_KEY>",
});
const resp = await client.chat.completions.create({
  "model": "m1",
  "messages": [
    {
      "role": "user",
      "content": "hi"
    }
  ],
  "temperature": 0.5,
  "max_tokens": 100
});
console.log(resp.choices[0].message.content);"
`;

