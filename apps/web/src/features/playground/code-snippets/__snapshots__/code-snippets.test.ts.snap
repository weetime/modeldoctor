exports[`genRerankSnippets > renders cohere wire (snapshot) 2`] = `
"import requests, json

resp = requests.post(
    "http://x/v1/rerank",
    headers={"Authorization": "Bearer <YOUR_API_KEY>", "Content-Type": "application/json"},
    data=json.dumps({
  "model": "m",
  "query": "q",
  "documents": [
    "a",
    "b"
  ],
  "top_n": 2
}),
)
print(resp.json())"
`;

exports[`genRerankSnippets > renders cohere wire (snapshot) 3`] = `
"const resp = await fetch("http://x/v1/rerank", {
  method: "POST",
  headers: {
    Authorization: "Bearer <YOUR_API_KEY>",
    "Content-Type": "application/json",
  },
  body: JSON.stringify({
  "model": "m",
  "query": "q",
  "documents": [
    "a",
    "b"
  ],
  "top_n": 2
}),
});
console.log(await resp.json());"
`;

