exports[`genImagesSnippets > renders prompt + size + n (snapshot) 2`] = `
"from openai import OpenAI

client = OpenAI(base_url="http://x", api_key="<YOUR_API_KEY>")
resp = client.images.generate(
    model="m",
    prompt="a red apple",
    size="512x512",
    n=1,
)
print(resp.data[0].url or resp.data[0].b64_json[:32])"
`;

