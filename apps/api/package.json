{
  "name": "@modeldoctor/api",
  "version": "0.1.0",
  "private": true,
  "description": "ModelDoctor API (NestJS)",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "scripts": {
    "build": "nest build",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:status": "prisma migrate status",
    "db:seed": "prisma db seed",
    "db:setup:test": "createdb modeldoctor_test 2>&1 | grep -v 'already exists' || true; psql -d modeldoctor_test -c \"GRANT ALL ON SCHEMA public TO modeldoctor; ALTER DATABASE modeldoctor_test OWNER TO modeldoctor;\" && DATABASE_URL=postgresql://modeldoctor:modeldoctor@localhost:5432/modeldoctor_test prisma migrate deploy && DATABASE_URL=postgresql://modeldoctor:modeldoctor@localhost:5432/modeldoctor_test prisma db seed",
    "db:studio": "prisma studio",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check src && pnpm check:env-example && pnpm check:e2e-env:test && pnpm check:e2e-env",
    "check:env-example": "node scripts/check-env-example.mjs",
    "check:e2e-env": "node scripts/check-e2e-no-env-mutation.mjs",
    "check:e2e-env:test": "node --test scripts/check-e2e-no-env-mutation.test.mjs",
    "format": "biome format --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "vitest run --config vitest.e2e.config.mts"
  },
  "dependencies": {
    "@kubernetes/client-node": "^0.21",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modeldoctor/contracts": "workspace:*",
    "@modeldoctor/tool-adapters": "workspace:*",
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.4.2",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.19.3",
    "argon2": "^0.44.0",
    "cookie-parser": "^1.4.7",
    "nanoid": "^5.1.11",
    "nestjs-pino": "^4",
    "nestjs-zod": "^5.3.0",
    "p-limit": "^3.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^10",
    "pino-http": "^11",
    "prisma": "^6.19.3",
    "reflect-metadata": "^0.2",
    "rxjs": "^7",
    "zod": "^3.23"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.19",
    "@swc/core": "^1",
    "@testcontainers/postgresql": "^11.14.0",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5",
    "@types/multer": "^2.1.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/supertest": "^6",
    "dotenv": "^17.4.1",
    "pino-pretty": "^11",
    "supertest": "^7",
    "testcontainers": "^11.14.0",
    "tsx": "^4.22.3",
    "unplugin-swc": "^1",
    "vite-tsconfig-paths": "^5",
    "vitest": "^2"
  }
}
