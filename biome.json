{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "files": {
    "includes": ["**", "!**/dist", "!**/node_modules", "!**/coverage", "!**/.vite"]
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    },
    "formatter": {
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "trailingCommas": "all",
      "semicolons": "always"
    }
  },
  "css": {
    "parser": { "cssModules": true, "tailwindDirectives": true }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "useAriaPropsSupportedByRole": "warn",
        "useSemanticElements": "warn"
      },
      "style": {
        "noUselessElse": "warn",
        "useConst": "warn",
        "useImportType": "off",
        "useNodejsImportProtocol": "error",
        "noCommonJs": "error"
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noArrayIndexKey": "warn",
        "noTemplateCurlyInString": "warn",
        "noAssignInExpressions": "warn",
        "noUnknownAtRules": "off"
      },
      "correctness": {
        "useExhaustiveDependencies": "warn"
      },
      "complexity": { "noForEach": "warn" }
    }
  },
  "overrides": [
    {
      "includes": ["**/apps/api/**/*.ts"],
      "linter": {
        "rules": {
          "style": { "noCommonJs": "off" }
        }
      }
    }
  ]
}
